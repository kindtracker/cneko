import std:io;

fn fib(n: int) {
  int prev0 = 1;
  int prev1 = 0;
  for (int i = 0; i < n; i++) {
    if (i > 2) {
      int curr = prev0 + prev1;
      prev1 = prev0;
      prev0 = curr;
      io:printfn("%d", curr);
		} else if (i == 1) {
      io:printfn("%d", prev1);
    } else if (i == 2) {
      io:printfn("%d", prev0);
    }
  }
}

fn main() {
  fib(16)  
}
